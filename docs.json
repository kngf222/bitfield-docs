{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bitfield",
  "description": "Public docs for Bitfield, the plug-in runtime and database for products that need to stay fast as they grow.",
  "colors": {
    "primary": "#4F62FF",
    "light": "#85F0B5",
    "dark": "#4F62FF"
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": {
      "family": "SF Pro Display",
      "source": "/fonts/SF-Pro-Display-Semibold.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "SF Pro Display",
      "source": "/fonts/SF-Pro-Display-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Start",
        "groups": [
          {
            "group": "Get moving",
            "pages": [
              "index",
              "start/quickstart",
              "start/get-your-key"
            ]
          },
          {
            "group": "Understand",
            "pages": [
              "concepts/what-is-bitfield",
              "concepts/database-and-runtime",
              "concepts/storage-shape",
              "concepts/content-addressed-storage",
              "concepts/slots",
              "concepts/active-devices"
            ]
          }
        ]
      },
      {
        "tab": "Runtime Kit",
        "groups": [
          {
            "group": "Use Runtime Kit",
            "pages": [
              "runtime-kit/javascript",
              "runtime-kit/use-bitfield-data",
              "runtime-kit/send-request",
              "runtime-kit/packages",
              "runtime-kit/local-state"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/runtime-kit-api",
              "reference/package-boundary"
            ]
          }
        ]
      },
      {
        "tab": "Workflows",
        "groups": [
          {
            "group": "Package examples",
            "pages": [
              "workflows/index",
              "workflows/package-set-with-one-record",
              "workflows/package-owned-file",
              "workflows/callable-package-slot",
              "workflows/react-surface-for-package-data"
            ]
          }
        ]
      },
      {
        "tab": "Build",
        "groups": [
          {
            "group": "Own your surface",
            "pages": [
              "build-your-own-surface/sdk-boundary"
            ]
          },
          {
            "group": "Activation",
            "pages": [
              "activation/trials-and-billing"
            ]
          }
        ]
      },
      {
        "tab": "Proof",
        "groups": [
          {
            "group": "Speed claims",
            "pages": [
              "proof/how-bitfield-is-fast",
              "proof/warm-and-cold-paths",
              "proof/benchmark-ledger",
              "proof/methodology",
              "reference/claim-ledger"
            ]
          },
          {
            "group": "Updates",
            "pages": [
              "changelog/index"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Bitfield",
        "href": "https://bitfield.so"
      },
      {
        "label": "Support",
        "href": "mailto:support@bitfield.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get My Key",
      "href": "https://bitfield.so/#pricing"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  }
}
