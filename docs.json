{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bitfield",
  "description": "World's fastest plug-in runtime and database for founders who can't afford to slow down when plans change.",
  "colors": {
    "primary": "#4F62FF",
    "light": "#85F0B5",
    "dark": "#4F62FF"
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "metadata": {
    "timestamp": true
  },
  "search": {
    "prompt": "Search Bitfield docs..."
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "canonical": "https://docs.bitfield.so",
      "description": "Build fast today and keep your 100th feature as fast as your first with Bitfield.",
      "keywords": "Bitfield, plug-in runtime, local-first database, runtime kit, offline software, active devices, content-addressed storage, founder developer tools",
      "robots": "index, follow",
      "googlebot": "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1",
      "application-name": "Bitfield",
      "apple-mobile-web-app-title": "Bitfield",
      "apple-mobile-web-app-capable": "yes",
      "apple-mobile-web-app-status-bar-style": "default",
      "format-detection": "telephone=no",
      "og:site_name": "Bitfield Docs",
      "og:type": "website",
      "og:url": "https://docs.bitfield.so",
      "og:title": "Bitfield Docs",
      "og:description": "Build fast today and keep your 100th feature as fast as your first with Bitfield.",
      "og:image": "https://docs.bitfield.so/social/bitfield-social-card-og-1200x630.png",
      "og:image:width": "1200",
      "og:image:height": "630",
      "og:image:type": "image/png",
      "og:image:alt": "World's fastest plug-in runtime and database for founders who can't afford to slow down when plans change. Bitfield.",
      "twitter:card": "summary_large_image",
      "twitter:title": "Bitfield Docs",
      "twitter:description": "Build fast today and keep your 100th feature as fast as your first with Bitfield.",
      "twitter:image": "https://docs.bitfield.so/social/bitfield-social-card-x-1200x600.png",
      "twitter:image:alt": "World's fastest plug-in runtime and database for founders who can't afford to slow down when plans change. Bitfield."
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": {
      "family": "SF Pro Display",
      "source": "/fonts/SF-Pro-Display-Semibold.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "SF Pro Display",
      "source": "/fonts/SF-Pro-Display-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Start",
        "groups": [
          {
            "group": "Get moving",
            "pages": [
              "index",
              "start/quickstart",
              "start/get-your-key"
            ]
          },
          {
            "group": "Understand",
            "pages": [
              "manifesto",
              "concepts/what-is-bitfield",
              "concepts/database-and-runtime",
              "concepts/storage-shape",
              "concepts/content-addressed-storage",
              "concepts/slots",
              "concepts/active-devices"
            ]
          }
        ]
      },
      {
        "tab": "Runtime Kit",
        "groups": [
          {
            "group": "Use Runtime Kit",
            "pages": [
              "runtime-kit/javascript",
              "runtime-kit/use-bitfield-data",
              "runtime-kit/send-request",
              "runtime-kit/packages",
              "runtime-kit/local-state",
              "runtime-kit/ai-build-rules",
              "runtime-kit/troubleshooting"
            ]
          },
          {
            "group": "Understand Runtime Kit",
            "pages": [
              "runtime-kit/concept-map",
              "runtime-kit/placeable-surfaces"
            ]
          },
          {
            "group": "Runtime Kit Cookbook",
            "pages": [
              "runtime-kit/cookbook/index",
              "runtime-kit/package-to-screen",
              "runtime-kit/cookbook/package-set-with-one-record",
              "runtime-kit/cookbook/package-owned-file",
              "runtime-kit/cookbook/callable-package-slot",
              "runtime-kit/cookbook/react-surface-for-package-data",
              "runtime-kit/cookbook/placeable-surface-product-loop"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/runtime-kit-api",
              "reference/package-boundary"
            ]
          }
        ]
      },
      {
        "tab": "Build",
        "groups": [
          {
            "group": "Build a product",
            "pages": [
              "build-your-own-surface/index",
              "build-your-own-surface/app-surfaces",
              "build-your-own-surface/package-authoring",
              "build-your-own-surface/target-design",
              "build-your-own-surface/product-shells",
              "build-your-own-surface/device-deployment",
              "build-your-own-surface/sdk-boundary"
            ]
          },
          {
            "group": "Activation",
            "pages": [
              "activation/account-and-key-flow",
              "activation/trials-and-billing",
              "activation/active-devices",
              "activation/plan-changes-and-cancellation"
            ]
          }
        ]
      },
      {
        "tab": "Proof",
        "groups": [
          {
            "group": "Speed claims",
            "pages": [
              "proof/how-bitfield-is-fast",
              "proof/warm-and-cold-paths",
              "proof/benchmark-ledger",
              "proof/methodology",
              "proof/comparison-guardrails",
              "proof/objection-faq",
              "reference/claim-ledger"
            ]
          },
          {
            "group": "Updates",
            "pages": [
              "changelog/index"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Bitfield",
        "href": "https://bitfield.so"
      },
      {
        "label": "Support",
        "href": "mailto:support@bitfield.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get My Key",
      "href": "https://account.bitfield.so"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  }
}
